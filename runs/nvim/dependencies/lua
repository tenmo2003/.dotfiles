#!/usr/bin/env bash

# === Configuration ===
LUA_VERSION="5.1.5"
LUAROCKS_VERSION="3.11.0"

# === Helper function to check command existence ===
function command_exists {
    command -v "$1" >/dev/null 2>&1
}

function install_dependencies {
    # package names in Debian form; helper translates per distro
    source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../../../lib/package-manager.sh"

    echo "Installing required system packages..."
    pkg_install build-essential libreadline-dev unzip curl || return 1
}

# === Install Lua ===
function install_lua {
    if command_exists lua; then
        INSTALLED_LUA_VERSION=$(lua -v 2>&1 | awk '{print $2}')
        if [[ "$INSTALLED_LUA_VERSION" == "$LUA_VERSION" ]]; then
            echo "Lua $LUA_VERSION is already installed."
            return
        else
            echo "Different Lua version detected: $INSTALLED_LUA_VERSION. Installing $LUA_VERSION..."
        fi
    else
        echo "Lua not found. Installing Lua $LUA_VERSION..."
    fi

    LUA_TAR="lua-${LUA_VERSION}.tar.gz"
    curl -fR -O "https://www.lua.org/ftp/${LUA_TAR}" || return 1
    tar -xzf "$LUA_TAR" || { rm -f "$LUA_TAR"; return 1; }
    # build in a subshell: a failure can't leak a cwd change into the sourcing installer shell
    if ! (cd "lua-${LUA_VERSION}" && make linux test && sudo make install); then
        rm -rf "lua-${LUA_VERSION}" "$LUA_TAR"
        return 1
    fi
    rm -rf "lua-${LUA_VERSION}" "$LUA_TAR"
}

# === Install LuaRocks ===
function install_luarocks {
    if command_exists luarocks; then
        INSTALLED_LUAROCKS_VERSION=$(luarocks --version | head -n 1 | awk '{print $2}')
        if [[ "$INSTALLED_LUAROCKS_VERSION" == "$LUAROCKS_VERSION" ]]; then
            echo "LuaRocks $LUAROCKS_VERSION is already installed."
            return
        else
            echo "Different LuaRocks version detected: $INSTALLED_LUAROCKS_VERSION. Installing $LUAROCKS_VERSION..."
        fi
    else
        echo "LuaRocks not found. Installing LuaRocks $LUAROCKS_VERSION..."
    fi

    LR_TAR="luarocks-${LUAROCKS_VERSION}.tar.gz"
    curl -fR -O "https://luarocks.github.io/luarocks/releases/${LR_TAR}" || return 1
    tar -xzf "$LR_TAR" || { rm -f "$LR_TAR"; return 1; }
    # build in a subshell: a failure can't leak a cwd change into the sourcing installer shell
    if ! (cd "luarocks-${LUAROCKS_VERSION}" && ./configure --with-lua-include=/usr/local/include && make && sudo make install); then
        rm -rf "luarocks-${LUAROCKS_VERSION}" "$LR_TAR"
        return 1
    fi
    rm -rf "luarocks-${LUAROCKS_VERSION}" "$LR_TAR"
}

# === Main ===
if ! install_dependencies; then
    echo "Failed to install system packages; skipping Lua/LuaRocks build."
    return 1 2>/dev/null || exit 1
fi
if ! install_lua; then
    echo "Lua installation failed."
    return 1 2>/dev/null || exit 1
fi
if ! install_luarocks; then
    echo "LuaRocks installation failed."
    return 1 2>/dev/null || exit 1
fi

echo "Installation completed."
